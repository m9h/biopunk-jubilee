                  performance''}
}

@misc{mas865,
  author       = {{Center for Bits and Atoms}},
  title        = {{MAS.865}: Rapid-Prototyping of Rapid-Prototyping Machines ---
                  How to Make Something that Makes (almost) Anything},
  howpublished = {\url{https://fab.cba.mit.edu/classes/865.24/}},
  year         = {2024},
  note         = {MIT. The lineage's flagship machine-building class. Its 14 weeks include
                  \emph{metrology}, real-time computing and communications, path planning,
                  control, and vision systems. Note what the metrology module actually teaches:
                  ``accuracy and precision, relative and absolute, single-ended and differential,
                  bits and oversampling, acquisition rate and Nyquist'' and sensors ``ready for
                  integration into projects.'' This is metrology-as-\emph{sensing} --- how to make
                  a machine perceive --- not metrology-as-\emph{machine-characterisation}: no error
                  budgets, no Abbe error, no kinematic-coupling repeatability, no ISO 230}
}

@misc{mtm_cba,
